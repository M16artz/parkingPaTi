# Plantilla de variables de entorno del backend.
# Copiar como backend/.env y completar fuera de Git. Los valores vacios son intencionales.

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
# Agregar aquí la IP LAN del equipo cuando Expo se ejecute en un teléfono físico.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

DB_NAME=parkingpati_db
DB_USER=postgres
DB_PASSWORD='Patinio111'
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=0
DB_SSL_REQUIRE=False

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=

# Sesion web. El refresh se mantiene en cookie HttpOnly.
JWT_REFRESH_COOKIE_NAME=parkingpati_refresh
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

# Gmail / Google Workspace SMTP
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=
FRONTEND_BASE_URL=
EMAIL_VERIFICATION_TTL_SECONDS=86400

# Limites aprobados para Loja
LOJA_MIN_LNG=-79.2770
LOJA_MIN_LAT=-4.0800
LOJA_MAX_LNG=-79.1300
LOJA_MAX_LAT=-3.8950
LOJA_BBOX_TOLERANCE=0.01

# Google Drive (storage_backends.py)
GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_FOLDER_ID=
