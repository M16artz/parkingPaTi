{
  "expo": {
    "name": "ParkingPaTi Móvil",
    "slug": "parkingpati",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logoM.png",
      "resizeMode": "contain",
      "backgroundColor": "#041333"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.m16artz.parkingpati",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#041333",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1b31ac2a-753b-495f-9a89-adba96204284"
      }
    },
    "owner": "mikelmzs-team"
  }
}
