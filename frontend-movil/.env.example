# URL pública HTTPS de Django, sin barra final. Sustituir el host en cada entorno.
EXPO_PUBLIC_API_BASE_URL=https://example.invalid/api/v1

# Sitio web HTTPS usado por el botón Ingresar. El móvil mantiene su alcance anónimo.
EXPO_PUBLIC_WEB_BASE_URL=https://app.example.invalid

# Opcional: tiles HTTPS con variables {z}, {x}, {y}. Si se omite, usa el mapa nativo.
EXPO_PUBLIC_MAP_TILE_URL=
EXPO_PUBLIC_MAP_ATTRIBUTION=Proveedor de mapa nativo
